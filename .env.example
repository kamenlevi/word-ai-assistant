OPENROUTER_KEY=your_openrouter_key_here
GROQ_KEY=your_groq_key_here

# Web search — pick ONE provider (Google is default).
# Google Custom Search: 100 free queries/day, $5/1k after.
#   1. Create an API key at https://console.cloud.google.com/apis/credentials
#   2. Create a Custom Search Engine at https://programmablesearchengine.google.com
#      and set "Search the entire web" ON; copy the cx (Search Engine ID).
GOOGLE_KEY=your_google_api_key_here
GOOGLE_CX=your_custom_search_engine_id_here

# Alternative provider — Brave Search (2,000 free queries/month).
# If both GOOGLE_KEY and BRAVE_KEY are set, WEB_SEARCH_PROVIDER picks which one.
BRAVE_KEY=your_brave_search_api_key_here

# 'google' (default) or 'brave'
WEB_SEARCH_PROVIDER=google
